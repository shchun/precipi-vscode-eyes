{
  "name": "eyes",
  "displayName": "Eyes",
  "description": "A pair of googly eyes that follow your cursor in VS Code. Inspired by vscode-pets.",
  "version": "0.0.3",
  "publisher": "precipi",
  "license": "MIT",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/shchun/precipi-vscode-eyes"
  },
  "galleryBanner": {
    "color": "#efe9df",
    "theme": "light"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "pets",
    "eyes",
    "fun",
    "cursor",
    "companion"
  ],
  "main": "./extension.js",
  "scripts": {
    "package": "node scripts/deploy.mjs --package",
    "deploy": "node scripts/deploy.mjs",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "mocha": "^10.7.3"
  },
  "activationEvents": [
    "onView:eyes.view",
    "onStartupFinished"
  ],
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "eyes.view",
          "name": "Eyes",
          "type": "webview",
          "icon": "media/eyes-icon.svg",
          "visibility": "visible"
        }
      ]
    },
    "configuration": {
      "title": "Eyes",
      "properties": {
        "eyes.reactToErrors": {
          "type": "boolean",
          "default": true,
          "description": "Make the eyes look anxious when the active file has errors or a terminal command fails."
        }
      }
    },
    "commands": [
      {
        "command": "eyes.start",
        "title": "Show Eyes",
        "category": "Eyes"
      },
      {
        "command": "eyes.surprise",
        "title": "Surprise!",
        "category": "Eyes"
      }
    ]
  }
}
